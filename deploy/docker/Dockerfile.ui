# syntax=docker/dockerfile:1
#
# 빌드 컨텍스트: 저장소 루트 (.)
#   docker build -f deploy/docker/Dockerfile.ui -t auth-ui:latest .

FROM node:24-alpine AS build
WORKDIR /repo
RUN corepack enable

COPY package.json yarn.lock .yarnrc.yml ./
COPY tsconfig.json ./
COPY .yarn/releases .yarn/releases

COPY service/package.json service/package.json
COPY ui/package.json ui/package.json
COPY service/interaction-ui/package.json service/interaction-ui/package.json

ENV YARN_NODE_LINKER=node-modules
ENV HUSKY=0
RUN yarn install --immutable

COPY ui ui

RUN yarn workspace @auth/ui build

FROM nginx:1.27-alpine AS runner
COPY --from=build /repo/ui/dist /usr/share/nginx/html
COPY deploy/docker/nginx-ui.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
