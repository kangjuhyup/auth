# 사용법: 이 파일을 secrets.env 로 복사한 뒤 값을 채우세요.
#   cp deploy/overlays/default/secrets.env.example deploy/overlays/default/secrets.env
# secrets.env 는 .gitignore 되어 있어 커밋되지 않습니다.
#
DB_USER=postgres
DB_PASSWORD=change-me
REDIS_URL=redis://redis.auth.svc.cluster.local:6379
OIDC_COOKIE_KEYS=replace-with-32chars-min-per-key-comma-separated
JWKS_ENCRYPTION_KEY=replace-with-64-char-hex
OTP_TOKEN_SECRET=replace-with-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SMTP_USER=
SMTP_PASS=
