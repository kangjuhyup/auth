{
  "name": "auth",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "ui",
    "service",
    "service/interaction-ui",
    "packages/*"
  ],
  "scripts": {
    "service:dev": "yarn workspace @auth/service start:dev",
    "service:build": "yarn workspace @auth/service build",
    "service:test": "yarn workspace @auth/service test",
    "service:test:unit": "yarn workspace @auth/service test:unit",
    "service:test:e2e": "E2E_ENV_FILE=service/.env.e2e yarn workspace @auth/service test:e2e --runInBand --watchman=false",
    "service:test:e2e:infra:up": "docker compose -f docker-compose.e2e.yml up -d postgres-e2e redis-e2e",
    "service:test:e2e:infra:down": "docker compose -f docker-compose.e2e.yml down -v --remove-orphans",
    "service:test:e2e:infra:logs": "docker compose -f docker-compose.e2e.yml logs -f postgres-e2e redis-e2e",
    "ui:dev": "yarn workspace @auth/ui dev",
    "ui:build": "yarn workspace @auth/ui build",
    "interaction-ui:build": "yarn workspace @auth/interaction-ui build",
    "dev": "yarn service:dev & yarn ui:dev",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}
