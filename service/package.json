{
  "name": "@auth/service",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migration:up": "mikro-orm migration:up",
    "migration:down": "mikro-orm migration:rollback",
    "migration:create": "mikro-orm migration:create",
    "migration:status": "mikro-orm migration:check",
    "schema:fresh": "mikro-orm schema:drop --run --drop-migrations-table && mikro-orm migration:up"
  },
  "dependencies": {
    "@mikro-orm/cli": "6.6.12",
    "@mikro-orm/core": "6.6.12",
    "@mikro-orm/migrations": "6.6.12",
    "@mikro-orm/mssql": "6.6.12",
    "@mikro-orm/mysql": "6.6.12",
    "@mikro-orm/nestjs": "^6.1.1",
    "@mikro-orm/postgresql": "6.6.12",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@simplewebauthn/server": "^13.3.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "express": "^5.2.1",
    "ioredis": "^5.9.3",
    "nodemailer": "^8.0.1",
    "oidc-provider": "^9.6.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.9",
    "@types/oidc-provider": "^9.5.0",
    "@types/pg": "^8",
    "@types/supertest": "^6.0.2",
    "chokidar": "3.5.3",
    "jest": "^29.7.0",
    "jest-util": "^30.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsconfig-paths": "^4.2.0"
  },
  "resolutions": {
    "chokidar": "3.5.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "roots": [
      "<rootDir>/src",
      "<rootDir>/test"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(oidc-provider)/)"
    ],
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@domain/(.*)$": "<rootDir>/src/domain/$1",
      "^@application/(.*)$": "<rootDir>/src/application/$1",
      "^@infrastructure/(.*)$": "<rootDir>/src/infrastructure/$1",
      "^@presentation/(.*)$": "<rootDir>/src/presentation/$1"
    }
  }
}
